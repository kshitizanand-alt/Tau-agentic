# Copy to .env, fill in your key, then:  source .env
#
# A single Grid AI key powers everything. run_agentic.sh derives the rest:
#   - customer simulator -> OPENAI_API_BASE=<grid>/v1 , OPENAI_API_KEY=<key>
#   - agent brain (Claude Code) -> ANTHROPIC_BASE_URL=<grid> + every
#     ANTHROPIC_*_MODEL slot set to the --model you pass on the command line.

export GRID_AI_API_KEY="REPLACE_WITH_YOUR_KEY"

# Optional: override the gateway URL (default https://grid.ai.juspay.net)
# export GRID_URL="https://grid.ai.juspay.net"

# IMPORTANT: do NOT set a real ANTHROPIC_API_KEY or OPENAI_API_KEY pointing at
# the public vendors. Keeping only the Grid key means any mis-routed call fails
# loudly instead of silently hitting Anthropic/OpenAI.